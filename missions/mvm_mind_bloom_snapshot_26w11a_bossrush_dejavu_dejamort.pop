                Name "the bob"
                Class Scout
            }
        }

        WaveSpawn
        {
            Name "teleporthotfix"
            WaitBeforeStarting 5.1

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`arena_teleport_relay`, `Trigger`)
                      "
            }
        }

        // Boss 1 - Bigheaded Behemoth
        WaveSpawn
        {
            Name "Wave4_Boss1-BigheadedBehemoth"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 12.5
            WaitBetweenSpawns 0
            TotalCurrency 50

            TFBot
            {
                Template T_TFBot_Fat_Boss_Heavy_Champ
            }

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`letsgetthisshowrolling`, `Trigger`)
                      "
            }
            DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave4_Support1-GRUHeavies`)
                        EntFire(`pop_interface`, `$PauseWaveSpawn`, `Wave4_Support1-GRUHeavies`)
                        EntFire(`arena_bonkplant_boss_spawn_relay`, `Trigger`, null, 2.5)
                      "
            }
        }

        WaveSpawn // Support GRU Heavies
        {
            Name "Wave4_Support1-GRUHeavies"
            Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 4
            SpawnCount 2
            WaitBeforeStarting 20
            WaitBetweenSpawns 4
            TotalCurrency 100

            TFBot
            {
                Name "Lightweight Champ"
                Template T_TFBot_Heavyweapons_Heavyweight_Champ_Fast
            }
        }

        // Boss 2 - TON 618 Black Hole Pyro
        WaveSpawn
        {
            Name "Wave4_Boss2-TON618BlackHolePyro"
            WaitForAllDead "Wave4_Boss1-BigheadedBehemoth"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 7.5
            WaitBetweenSpawns 0
            TotalCurrency 50

            TFBot
            {
                Template T_TFBot_Fat_Boss_Pyro_BlackHole
            }

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$ResumeWaveSpawn`, `Wave4_Support1-GRUHeavies`, 2.5)
                      "
            }

            DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave4_Support1-GRUHeavies`)
                        EntFire(`pop_interface`, `$PauseWaveSpawn`, `Wave4_Support1-GRUHeavies`)
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave4_Support2-Pyros`)
                        EntFire(`pop_interface`, `$PauseWaveSpawn`, `Wave4_Support2-Pyros`)
                        EntFire(`arena_bonkplant_boss_spawn_relay`, `Trigger`, null, 2.5)
                      "
            }
        }

        WaveSpawn // Support Pyros
        {
            Name "Wave4_Support2-Pyros"
            WaitForAllSpawned "Wave4_Boss2-TON618BlackHolePyro"
            Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 4
            SpawnCount 1
            WaitBeforeStarting 5
            WaitBetweenSpawns 5
            TotalCurrency 100

            TFBot
