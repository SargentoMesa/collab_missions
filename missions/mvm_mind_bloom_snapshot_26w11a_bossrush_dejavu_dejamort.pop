    Wave // Main Boss - Slave Knight Dael OR Direct Disaster
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    if (!(`mvm_mind_bloom_playerattributes` in getroottable()))
                    {
                        IncludeScript(`mvm_mind_bloom_playerattributes`, getroottable())
                    }
                    if (!(`alternatewaves` in getroottable()))
                    {
                        IncludeScript(`alternatewaves`, getroottable());
                    }
                    if (!(`mvm_mind_bloom_arena_rng` in getroottable()))
                    {
                        IncludeScript(`mvm_mind_bloom_arena_rng`, getroottable());
                    }
                    if (!(`claudz_logic_v3` in getroottable()))
					{
						IncludeScript(`claudz_logic_v3`, getroottable());
					}
                    if (MusicSystemMent.MasterEntity == null || !MusicSystemMent.MasterEntity.IsValid())
					{
						MusicSystemMent.ResetAll();
						MusicSystemMent.HookByName(`bignet`);
					}
					MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/slimy_spring_galaxy.wav`, 2.0, 2.0, 0.75);

                    MindBloomRNG.AddRNGArena(`wave_init_arena_industrial_relay`, `Wave7_SlaveKnightDael`);
                    MindBloomRNG.AddRNGArena(`wave_init_arena_doppler_relay`, `Wave7_DirectDisaster`);
                    MindBloomRNG.InitRNGArena();

                    AlternateWaves.bTrackIcons = false;
				    AlternateWaves.ClearWaveIcons();

                    switch (MindBloomRNG.GlobalIndex)
                    {
                        case 0:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`dead_lite_dummy`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`scout`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`pyro_flare`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
                            ])
                            break;
                        }
                        
                        case 1:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`soldier_directhit_lite_giant`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`demoknight_claymore_kai`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`demo`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
                            ])
                            break;
                        }
                    }
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)

                    AlternateWaves.ClearWaveIcons();

                    switch (MindBloomRNG.GlobalIndex)
                    {
                        case 0:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`dead_lite_dummy`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`scout`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`pyro_flare`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
                            ])
                            break;
                        }
                        
                        case 1:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`soldier_directhit_lite_giant`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`demoknight_claymore_kai`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`demo`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
                            ])
                            break;
                        }
                    }

                    MindBloomRNG.StartRNGArena();
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`boss_rush_spawn_teleport_relay`, `Trigger`, null, 5)

                    AlternateWaves.bTrackIcons = true;
                  "
        }
    
        CustomMaxWaveNumber 0
        RedTeamWipeCausesWaveLoss 1

        WaveSpawn
        {
            Name "teleporthotfix"
            WaitBeforeStarting 5.1

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`arena_teleport_relay`, `Trigger`)
                        MusicSystemMent.SetMusicTrack(``, 2.0, 2.0);
						EntFire(`tf_gamerules`, `PlayVO`, `boss_incoming.wav`, 2.4)
                      "
            }
        }

        //// Slave Knight Dael ////
        WaveSpawn
        {
            Name "Wave7_SlaveKnightDael"
            StartDisabled 1
        }
        WaveSpawn // Boss
        {
            Name "Wave7_Boss-SlaveKnightDael"
            WaitForAllSpawned "Wave7_SlaveKnightDael"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 12.5
            WaitBetweenSpawns 0
            TotalCurrency 100

            TFBot
            {
                Template T_TFBot_Fat_Boss_Slave_Knight
                Action Mobber
            }
            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        MusicSystemMent.SetMusicTrack(`#mainbosstheme1.mp3`);
                      "
            }
            DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave7_Support-Scouts`)
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave7_Support-FlarePyros`)
                        EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave7_Support-Scouts`)
                        EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave7_Support-FlarePyros`)
                        EntFire(`pop_interface`, `$FinishWaveNoUnspawnedMoney`)
                      "
            }
        }

        WaveSpawn // Support Scouts
        {
            Name "Wave7_Support-Scouts"
            WaitForAllSpawned "Wave7_SlaveKnightDael"
            Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 7
            SpawnCount 5
            WaitBeforeStarting 20
            WaitBetweenSpawns 12
            TotalCurrency 100

            TFBot
            {
                Class Scout
                Skill Easy
                Action Mobber
            }
        }
        WaveSpawn // Support Flare Pyros
        {
            Name "Wave7_Support-FlarePyros"
            WaitForAllSpawned "Wave7_SlaveKnightDael"
            Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 4
            SpawnCount 2
            WaitBeforeStarting 20
            WaitBetweenSpawns 4
            TotalCurrency 100

            TFBot
            {
                Template T_TFBot_Pyro_Flaregun
                Action Mobber
            } 
        }

        //// Direct Disaster ////
        WaveSpawn
        {
            Name "Wave7_DirectDisaster"
            StartDisabled 1
        }
        WaveSpawn // Boss
        {
            Name "Wave7_Boss-DirectDisaster"
            WaitForAllSpawned "Wave7_DirectDisaster"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 12.5
            WaitBetweenSpawns 0
            TotalCurrency 100

            TFBot
            {
                Template T_TFBot_Direct_Disaster_Boss
                Action Mobber
            }
            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        MusicSystemMent.SetMusicTrack(`#mainbosstheme1.mp3`);
                      "
            }
            DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave7_Support-ClaymoreKnights`)
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave7_Support-Demomen`)
                        EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave7_Support-ClaymoreKnights`)
                        EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave7_Support-Demomen`)
                        EntFire(`pop_interface`, `$FinishWaveNoUnspawnedMoney`)
                      "
            }
        }

        WaveSpawn // Support Claymore Knights
        {
            Name "Wave7_Support-ClaymoreKnights"
            WaitForAllSpawned "Wave7_DirectDisaster"
            Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 6
            SpawnCount 2
            WaitBeforeStarting 20
            WaitBetweenSpawns 5
            TotalCurrency 100

            TFBot
            {
                Name "Claidheamh Mor Knight"
                Template T_TFBot_Demoman_Knight
                ClassIcon demoknight_claymore_kai
                Action Mobber

                Item "The Claidheamohmor"
            }
        }
        WaveSpawn // Support Demomen
        {
            Name "Wave7_Support-Demomen"
            WaitForAllSpawned "Wave7_DirectDisaster"
            Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 4
            SpawnCount 2
            WaitBeforeStarting 20
            WaitBetweenSpawns 8
            TotalCurrency 100

            TFBot
            {
                Class Demoman
                Skill Easy
                Action Mobber
            }
        }
