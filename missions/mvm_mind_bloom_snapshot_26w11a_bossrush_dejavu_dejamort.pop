    Wave // Main Boss - Overclocked Dave Reborn
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_init_arena_terrorlict_relay`, `Trigger`, null, 6)

                    if (!(`mvm_mind_bloom_playerattributes` in getroottable()))
                    {
                        IncludeScript(`mvm_mind_bloom_playerattributes`, getroottable())
                    }
					IncludeScript(`tankextensions_main`, getroottable())
					IncludeScript(`tankextensions/combattank`, getroottable())
                	IncludeScript(`tankextensions/combattank_weapons/rocketpod`, getroottable())
                	IncludeScript(`tankextensions/combattank_weapons/railgun`, getroottable())

                    TankExt.CreateLoopPaths({
                        tank_loop = [
                            Vector(13504, 5440, -256)    // tank_path_1
							Vector(12992, 5440, -1088)    // tank_path_2
							Vector(12672, 5312, -1088)    // tank_path_3
							Vector(12480, 5120, -1088)    // tank_path_4
							Vector(12416, 4800, -1088)    // tank_path_5
							Vector(12480, 3712, -1024)    // tank_path_6
							Vector(12416, 3520, -1024)    // tank_path_7
							Vector(12160, 3392, -1024)    // tank_path_8
							Vector(11904, 3392, -1024)    // tank_path_9
							Vector(11776, 3456, -1024)    // tank_path_10
							Vector(11648, 3584, -1024)    // tank_path_11
							Vector(11584, 3904, -1024)    // tank_path_12
							Vector(11712, 4352, -1024)    // tank_path_13
							Vector(11712, 4928, -1088)    // tank_path_14
							Vector(11840, 5248, -1088)    // tank_path_15
							Vector(12032, 5376, -1088)    // tank_path_16
							Vector(12288, 5376, -1088)    // tank_path_17
							Vector(12480, 5120, -1088)    // tank_path_18
                        ]
                    })

					TankExt.SetValueOverrides({
                        COMBATTANK_ROTATE_SPEED_DEFAULT = 1.4   // default: 0.8
                        COMBATTANK_MAX_RANGE = 2000            // default: 1400
                    })

                    if (MusicSystemMent.MasterEntity == null || !MusicSystemMent.MasterEntity.IsValid())
					{
						MusicSystemMent.ResetAll();
						MusicSystemMent.HookByName(`bignet`);
					}
					MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/where_the_true_enemy_lies.wav`, 2.0, 2.0, 0.75);
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`boss_rush_spawn_teleport_relay`, `Trigger`, null, 5)
                  "
        }

        CustomWaveNumber 19
        CustomMaxWaveNumber 0
        RedTeamWipeCausesWaveLoss 1

        WaveSpawn
        {
            Name "teleporthotfix"
            WaitBeforeStarting 5.1

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`arena_teleport_relay`, `Trigger`)
                        MusicSystemMent.SetMusicTrack(``, 2.0, 2.0);
						EntFire(`tf_gamerules`, `PlayVO`, `boss_incoming.wav`, 2.4)
                      "
            }
        }

        WaveSpawn // Boss
        {
            Name "Wave19_Boss-OverclockedDaveReborn"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 12.5
            WaitBetweenSpawns 0
            TotalCurrency 100

            TFBot
            {
                Template DaveReborn
                Action Mobber
            }
            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        MusicSystemMent.SetMusicTrack(`#expert_boss_theme.mp3`);
                      "
            }
			DoneOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave19_Support-Soldiers`)
						EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave19_Support-ArmoredBatScouts`)
						EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave19_Support-Soldiers`)
						EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave19_Support-ArmoredBatScouts`)
					  "
			}
        }
        WaveSpawn // Tank # HP
        {
            Name "getdisablednoob"
            WaitForAllDead ""
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 0
            StartDisabled 1
            TotalCurrency 0
        
            Tank
            {
                Name "combattank|rocketpod_homing|railgun"
                StartingPathTrackNode "tank_loop_1"
                ClassIcon 	tank_combat_railgun_homingburst
                SpawnTemplate teleforbossafterdeath
                Health 40000
                Speed 75
                Skin 0
        
                OnKilledOutput 
                {
                    Target "aftercombattank"
                    Action Trigger
                }
                OnBombDroppedOutput
                {
                    Target boss_deploy_relay
                    Action Trigger
                }
            }
        }

		WaveSpawn
		{
			Name "Wave20_DaveDead"
			WaitForAllDead "Wave19_Boss-OverclockedDaveReborn"
			WaitBeforeStarting 10
		}
        WaveSpawn // Support Soldiers
        {
            Name "Wave19_Support-Soldiers"
            Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 8
            SpawnCount 2
            WaitBeforeStarting 20
            WaitBetweenSpawns 6
            TotalCurrency 100

            TFBot
            {
                Class Soldier
                Skill Expert
                Action Mobber
            }
        }
        WaveSpawn // Support Armored Bat Scouts
        {
            Name "Wave19_Support-ArmoredBatScouts"
            Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 3
            SpawnCount 1
            WaitBeforeStarting 20
            WaitBetweenSpawns 6
            TotalCurrency 100

            TFBot
            {
                Name "Armored Bat Scout"
                Template T_TFBot_Scout_Melee
                ClassIcon scout_bat_nys_armored
                Scale 1.4
                Health 900
                Action Mobber
            }
        }
    }
