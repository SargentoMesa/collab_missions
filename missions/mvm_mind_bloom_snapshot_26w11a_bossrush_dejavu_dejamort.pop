                        EntFire(`arena_electricmine_barrier`, `Close`)
                        EntFire(`backupteleporting`, `Kill`)
                        EntFire(`player,SetScriptOverlayMaterial,,5,-1`)
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave19_TheHeavies`)
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `disableformidboss`)
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `forthesplashattack`)
                        EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave19_TheHeavies`)
                        EntFire(`pop_interface`, `$FinishWaveSpawn`, `disableformidboss`)
                        EntFire(`pop_interface`, `$FinishWaveSpawn`, `forthesplashattack`)
                        EntFire(`pop_interface`, `$FinishWaveNoUnspawnedMoney`, null, 10)
