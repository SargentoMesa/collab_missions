    Wave // Main Boss - Chaos Surge OR Colonel Conduit OR The Master Mechanic OR Nemesis Program MKII: Mimicry
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					if (!(`mvm_mind_bloom_playerattributes` in getroottable()))
					{
						IncludeScript(`mvm_mind_bloom_playerattributes`, getroottable())
					}
					if (!(`alternatewaves` in getroottable()))
					{
						IncludeScript(`alternatewaves`, getroottable());
					}
					if (!(`mvm_mind_bloom_arena_rng` in getroottable()))
					{
						IncludeScript(`mvm_mind_bloom_arena_rng`, getroottable());
					}
					if (MusicSystemMent.MasterEntity == null || !MusicSystemMent.MasterEntity.IsValid())
					{
						MusicSystemMent.ResetAll();
						MusicSystemMent.HookByName(`bignet`);
					}
					MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/slimy_spring_galaxy.wav`, 2.0, 2.0, 0.75);

					if (!(`rangescript_v2` in getroottable()))
					{
						IncludeScript(`rangescript_v2`, getroottable());
					}

					IncludeScript(`tankextensions_main`, getroottable())
					IncludeScript(`tankextensions/combattank`, getroottable())
					IncludeScript(`tankextensions/combattank_weapons/minigun`, getroottable())
					IncludeScript(`tankextensions/combattank_weapons/rocketpod`, getroottable())
					IncludeScript(`tankextensions/combattank_weapons/railgun`, getroottable())

					TankExt.CreateLoopPaths({
						tank_mechanic = [
							Vector(-6143, -5249, -612)
							Vector(-6400, -5249, -612)
							Vector(-7000, -5249, -612)
							Vector(-6143, -5249, -612)
						]
					})

					TankExt.SetValueOverrides({
						COMBATTANK_ROTATE_SPEED_DEFAULT = 0.8   // default: 0.8
						COMBATTANK_MAX_RANGE = 2000            // default: 1400
					})

					MindBloomRNG.AddRNGArena(`wave_init_arena_industrial_relay`, `Wave11_ChaosSurge`);
					MindBloomRNG.AddRNGArena(`wave_init_arena_spyfactory_relay`, `Wave11_ColonelConduit`);
					MindBloomRNG.AddRNGArena(`wave_init_arena_cliffside_relay`, `Wave11_NemesisMimicry`);
					MindBloomRNG.AddRNGArena(`wave_init_arena_spyfactory_relay`, `Wave11_MasterMechanic`);
					MindBloomRNG.InitRNGArena();

					AlternateWaves.bTrackIcons = false;
					AlternateWaves.ClearWaveIcons();

					switch (MindBloomRNG.GlobalIndex)
					{
						case 0:
						{
							AlternateWaves.AddWaveIcons([
								[`pyro_hyper_lite`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`demo`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
								[`heavy`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
							])
							break;
						}                     
						case 1:
