                    Param "Wave5_Support-Heavies"
                    Delay 0.1
                    Repeats 1
                    Cooldown -1
                    IfHealthBelow 2
                }
                FireInput
                {
                    Target pop_interface
                    Action $FinishWaveSpawn
                    Param "Wave5_Support-Heavies"
                    Delay 0.1
                    Repeats 1
                    Cooldown -1
                    IfHealthBelow 2
                }
                FireInput
                {
                    Target pop_interface
                    Action $KillWaveSpawn
                    Param "Wave5_Support-Pyros"
