    Wave // Main Boss - The Three Trolldiers OR Planned Obsolescence OR The Foremann
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    if (!(`mvm_mind_bloom_playerattributes` in getroottable()))
                    {
                        IncludeScript(`mvm_mind_bloom_playerattributes`, getroottable())
                    }
                    if (!(`alternatewaves` in getroottable()))
                    {
                        IncludeScript(`alternatewaves`, getroottable());
                    }
                    if (!(`mvm_mind_bloom_arena_rng` in getroottable()))
                    {
                        IncludeScript(`mvm_mind_bloom_arena_rng`, getroottable());
                    }
                    if (MusicSystemMent.MasterEntity == null || !MusicSystemMent.MasterEntity.IsValid())
					{
						MusicSystemMent.ResetAll();
						MusicSystemMent.HookByName(`bignet`);
					}
					MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/where_the_true_enemy_lies.wav`, 2.0, 2.0, 0.75);

                    //MindBloomRNG.AddRNGArena(`wave_init_arena_electricmine_relay`, `Wave19_TrolldierTrio`);
                    MindBloomRNG.AddRNGArena(`wave_init_arena_electricmine_relay`, `Wave19_PlannedObsolescence`);
                    MindBloomRNG.AddRNGArena(`wave_init_arena_electricmine_relay`, `Wave19_Foremann`);
                    MindBloomRNG.InitRNGArena();

                    AlternateWaves.bTrackIcons = false;
				    AlternateWaves.ClearWaveIcons();

                    switch (MindBloomRNG.GlobalIndex)
                    {
                        //case 0:
                        //{
                        //    AlternateWaves.AddWaveIcons([
                        //        [`soldier_gib_jumper_lite`, 3, MVM_CLASS_FLAG_MINIBOSS],
                        //    ])
                        //    break;
                        //}

                        case 0:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`soldier_gib_lite_giant`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`heavy`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`pyro_homewrecker_lite_armored`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`soldier_conch`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`pyro_neon`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
                            ])
                            break;
                        }

                        case 1:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`pyro_fireaxe_lite_armored`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`heavy_steelfist`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`pyro_flare`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`scout_giant_fast`, 1, MVM_CLASS_FLAG_MINIBOSS | MVM_CLASS_FLAG_SUPPORT | MVM_CLASS_FLAG_ALWAYSCRIT]
                            ])
                            break;
                        }
                    }
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)

                    AlternateWaves.ClearWaveIcons();

                    switch (MindBloomRNG.GlobalIndex)
                    {
                        //case 0:
                        //{
                        //    AlternateWaves.AddWaveIcons([
                        //        [`soldier_gib_jumper_lite`, 3, MVM_CLASS_FLAG_MINIBOSS],
                        //    ])
                        //    break;
                        //}

                        case 0:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`soldier_gib_lite_giant`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`heavy`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`pyro_homewrecker_lite_armored`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`soldier_conch`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`pyro_neon`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
                            ])
                            break;
                        }

                        case 1:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`pyro_fireaxe_lite_armored`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`heavy_steelfist`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`pyro_flare`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`scout_giant_fast`, 1, MVM_CLASS_FLAG_MINIBOSS | MVM_CLASS_FLAG_SUPPORT | MVM_CLASS_FLAG_ALWAYSCRIT]
                            ])
                            break;
                        }
                    }

                    MindBloomRNG.StartRNGArena();
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`boss_rush_spawn_teleport_relay`, `Trigger`, null, 5)

                    AlternateWaves.bTrackIcons = true;
                  "
        }

        CustomWaveNumber 18
        CustomMaxWaveNumber 0
        RedTeamWipeCausesWaveLoss 1

        WaveSpawn
        {
            Name "teleporthotfix"
            WaitBeforeStarting 5.1

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`arena_teleport_relay`, `Trigger`)
                        MusicSystemMent.SetMusicTrack(``, 2.0, 2.0);
						EntFire(`tf_gamerules`, `PlayVO`, `boss_incoming.wav`, 2.4)
                      "
            }
        }

        //// The Three Trolldiers ////

        //// Planned Obsolescence ////
        WaveSpawn
        {
            Name "Wave19_PlannedObsolescence"
            StartDisabled 1
        }
        WaveSpawn
        {
            Name "Wave19_PlannedObsolescenceSetup"
