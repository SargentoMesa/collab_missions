                        EntFire(`pop_interface`, `$ResumeWaveSpawn`, `Wave4_Support2-Pyros`, 7.5)
                      "
            }
        }
        WaveSpawn
        {
            Name "Wave4_Boss3-KingBurst"
            WaitForAllDead "Wave4_Boss2-TON618BlackHolePyro"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 7.5
            WaitBetweenSpawns 0
            TotalCurrency 50

            TFBot
            {
                Template T_TFChief_King_Burst
            }
        }
    }
