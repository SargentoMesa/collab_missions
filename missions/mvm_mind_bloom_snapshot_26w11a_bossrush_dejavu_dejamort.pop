            MaxActive 4
            SpawnCount 2
            WaitBeforeStarting 20
            WaitBetweenSpawns 4
            TotalCurrency 100

            TFBot
            {
                Template T_TFBot_Pyro_Flaregun
                Action Mobber
            } 
        }

