						EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave13_Support-Soldiers`)
						EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave13_Support-TomislavHeavies`)
						EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave13_Support-BackburnerPyros`)
						EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave13_Support-Soldiers`)
						EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave13_Support-TomislavHeavies`)
						EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave13_Support-BackburnerPyros`)
                      "
            }
        }

		WaveSpawn
		{
			Name "Wave13_TonkaDeathAnim"
