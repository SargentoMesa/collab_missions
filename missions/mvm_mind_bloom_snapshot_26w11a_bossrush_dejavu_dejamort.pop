    Wave // Mini Boss - Major Bonecremator OR Distorted Messenger OR Private Seeker OR Nemesis Program MKI: Shell
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					if (!(`mvm_mind_bloom_playerattributes` in getroottable()))
					{
						IncludeScript(`mvm_mind_bloom_playerattributes`, getroottable())
					}
					if (!(`alternatewaves` in getroottable()))
					{
						IncludeScript(`alternatewaves`, getroottable());
					}
					if (!(`mvm_mind_bloom_arena_rng` in getroottable()))
					{
						IncludeScript(`mvm_mind_bloom_arena_rng`, getroottable());
					}
					if (!(`pyro_boss_special` in getroottable()))
					{
						IncludeScript(`pyro_boss_special`, getroottable());
					}
					if (!(`death_associate3` in getroottable()))
					{
						IncludeScript(`death_associate3`, getroottable());
					}
					if (MusicSystemMent.MasterEntity == null || !MusicSystemMent.MasterEntity.IsValid())
					{
						MusicSystemMent.ResetAll();
						MusicSystemMent.HookByName(`bignet`);
					}
					MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/slimy_spring_galaxy.wav`, 2.0, 2.0, 0.75);

					MindBloomRNG.AddRNGArena(`wave_init_arena_scallops_relay`, `Wave10_MajorBonecremator`);
					MindBloomRNG.AddRNGArena(`wave_init_arena_doppler_relay`, `Wave10_DistortedMessenger`);
					MindBloomRNG.AddRNGArena(`wave_init_arena_saxford_relay`, `Wave10_PrivateSeeker`);
					MindBloomRNG.AddRNGArena(`wave_init_arena_cliffside_relay`, `Wave10_NemesisShell`);
					MindBloomRNG.InitRNGArena();

					AlternateWaves.bTrackIcons = false;
					AlternateWaves.ClearWaveIcons();

					switch (MindBloomRNG.GlobalIndex)
					{
						case 0:
						{
							AlternateWaves.AddWaveIcons([
								[`pyro_phlog_skull`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`medic_shield_lite`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`heavy_deflector`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
								[`soldier_bazooka`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
							])
							break;
						}

						case 1:
						{
							AlternateWaves.AddWaveIcons([
								[`demo_atomic`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`heavy_shotgun`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`soldier_rocketwall`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`scout_bat_nys`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT | MVM_CLASS_FLAG_ALWAYSCRIT],
								[`pyro_backburner_nys`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
							])
							break;
						}

						case 2:
						{
							AlternateWaves.AddWaveIcons([
								[`soldier_barrage_homing_nys_giant`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`engineer_widowmaker_nys`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
								[`pyro_dragon_fury_swordstone`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
							])
							break;
						}

						case 3:
						{
							AlternateWaves.AddWaveIcons([
								[`soldier_bison`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`scout_popper2_giant`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
								[`heavy_champ`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT | MVM_CLASS_FLAG_ALWAYSCRIT]
							])
							break;
						}
					}
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)

                    AlternateWaves.ClearWaveIcons();

                    switch (MindBloomRNG.GlobalIndex)
                    {
                        case 0:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`pyro_phlog_skull`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`medic_shield_lite`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`heavy_deflector`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`soldier_bazooka`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
                            ])
                            break;
                        }

                        case 1:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`demo_atomic`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`heavy_shotgun`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`soldier_rocketwall`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`scout_bat_nys`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT | MVM_CLASS_FLAG_ALWAYSCRIT],
                                [`pyro_backburner_nys`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
                            ])
                            break;
                        }

                        case 2:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`soldier_barrage_homing_nys_giant`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`engineer_widowmaker_nys`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`pyro_dragon_fury_swordstone`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
