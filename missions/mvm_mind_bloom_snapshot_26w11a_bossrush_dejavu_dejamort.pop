        WaveSpawn // Support Demoknights
        {
            Name "Wave5_Support1-Demoknights"
            Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 4
            SpawnCount 1
            WaitBeforeStarting 20
            WaitBetweenSpawns 3
            TotalCurrency 100

            TFBot
            {
                Template T_TFBot_Demoman_Knight
            }
        }

        // Boss 2 - Fallen Pyro & Demo Patrol Chiefs
        WaveSpawn
        {
            Name "Wave5_Boss2-PyroPatrolChief"
            WaitForAllDead "Wave5_Boss1-HeavyPatrolChief"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 7.5
            WaitBetweenSpawns 0
            TotalCurrency 50

            TFBot
            {
                Template T_TFBot_Pyro_PatrolChief
            }

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$ResumeWaveSpawn`, `Wave5_Support1-Demomen`, 7.5)
                        EntFire(`pop_interface`, `$ResumeWaveSpawn`, `Wave5_Support1-Demoknights`, 7.5)
                      "
            }
        }
        WaveSpawn
        {
            Name "Wave5_Boss2-DemoPatrolChief"
            WaitForAllDead "Wave5_Boss1-HeavyPatrolChief"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 7.5
            WaitBetweenSpawns 0
            TotalCurrency 50

            TFBot
            {
                Template T_TFBot_Demo_PatrolChief
            }
        }
    }

    // ADVANCED GAUNTLET //

    Wave // Mini Boss - Drunken Drivers
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    Convars.SetValue(`tf_bot_flag_escort_max_count`, 0)
                    
                    IncludeScript(`mvm_mind_bloom_playerattributes`, getroottable())
                    EntFire(`wave_init_arena_spyfactory_relay`, `Trigger`, null, 6)
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`boss_rush_spawn_teleport_relay`, `Trigger`, null, 5)
                  "
        }

        RedTeamWipeCausesWaveLoss 1

        SpawnTemplate MiniBossRushMusic

        WaveSpawn // Dummy Bomb
        {
            Where spawnbot_bomb
            Support Limited
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 0

            HideIcon 1

            TFBot
            {
                Name "the bob"
                Class Scout
            }
        }

        WaveSpawn
        {
            Name "teleporthotfix"
            WaitBeforeStarting 5.1

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`arena_teleport_relay`, `Trigger`)
                      "
            }
        }

