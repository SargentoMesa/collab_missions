        {
            Name "Wave7_DirectDisaster"
            StartDisabled 1
        }
        WaveSpawn // Boss
        {
            Name "Wave7_Boss-DirectDisaster"
            WaitForAllSpawned "Wave7_DirectDisaster"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 12.5
            WaitBetweenSpawns 0
            TotalCurrency 100

            TFBot
            {
                Template T_TFBot_Direct_Disaster_Boss
                Action Mobber
            }
            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`mainbossmusicinit`, `Trigger`)
                      "
            }
            DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$FinishWaveNoUnspawnedMoney`)
                      "
            }
        }
    }
