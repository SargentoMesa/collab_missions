        // Boss 3 - General Bomber and King Burst
        WaveSpawn
        {
            Name "Wave4_Boss3-GeneralBomber"
            WaitForAllDead "Wave4_Boss2-TON618BlackHolePyro"
            Where spawnbot_boss
