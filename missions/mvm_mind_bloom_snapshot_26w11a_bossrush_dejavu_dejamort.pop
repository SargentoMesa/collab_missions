                        EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave18_Support-SteelGauntlets`)
                        EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave18_Support-FlarePyros`)
                        EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave18_Support-SuperScouts`)
