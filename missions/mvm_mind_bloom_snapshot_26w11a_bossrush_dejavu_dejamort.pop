							AlternateWaves.AddWaveIcons([
								[`engineer_hyper`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`soldier`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
								[`pyro_flare`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
								[`scout_stun`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
							])
