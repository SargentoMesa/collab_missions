    Wave // Main Boss - The Three Trolldiers OR Planned Obsolescence OR The Foremann
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    if (!(`mvm_mind_bloom_playerattributes` in getroottable()))
                    {
                        IncludeScript(`mvm_mind_bloom_playerattributes`, getroottable())
                    }
                    if (!(`alternatewaves` in getroottable()))
                    {
                        IncludeScript(`alternatewaves`, getroottable());
                    }
                    if (!(`mvm_mind_bloom_arena_rng` in getroottable()))
                    {
                        IncludeScript(`mvm_mind_bloom_arena_rng`, getroottable());
                    }

                    MindBloomRNG.AddRNGArena(`wave_init_arena_electricmine_relay`, `Wave18_TrolldierTrio`);
                    MindBloomRNG.AddRNGArena(`wave_init_arena_electricmine_relay`, `Wave18_PlannedObsolescence`);
                    MindBloomRNG.AddRNGArena(`wave_init_arena_electricmine_relay`, `Wave18_Foremann`);
                    MindBloomRNG.InitRNGArena();

                    AlternateWaves.bTrackIcons = false;
				    AlternateWaves.ClearWaveIcons();

                    switch (MindBloomRNG.GlobalIndex)
                    {
                        case 0:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`soldier_gib_jumper_lite`, 3, MVM_CLASS_FLAG_MINIBOSS],
                            ])
                            break;
                        }

                        case 1:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`soldier_gib_lite_giant`, 1, MVM_CLASS_FLAG_MINIBOSS]
                            ])
                            break;
                        }

                        case 2:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`pyro_fireaxe_lite_armored`, 1, MVM_CLASS_FLAG_MINIBOSS]
                            ])
                            break;
                        }
                    }
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)

                    AlternateWaves.ClearWaveIcons();

                    switch (MindBloomRNG.GlobalIndex)
                    {
                        case 0:
                        {
                            AlternateWaves.AddWaveIcons([
                                [``, 3, MVM_CLASS_FLAG_MINIBOSS],
                            ])
                            break;
                        }

                        case 1:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`soldier_gib_lite_giant`, 1, MVM_CLASS_FLAG_MINIBOSS]
                            ])
                            break;
                        }

                        case 2:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`pyro_fireaxe_lite_armored`, 1, MVM_CLASS_FLAG_MINIBOSS]
                            ])
                            break;
                        }
                    }

                    MindBloomRNG.StartRNGArena();
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`boss_rush_spawn_teleport_relay`, `Trigger`, null, 5)

                    AlternateWaves.bTrackIcons = true;
                  "
        }

        RedTeamWipeCausesWaveLoss 1

        SpawnTemplate MainBossMusic

        WaveSpawn
        {
            Name "teleporthotfix"
            WaitBeforeStarting 5.1

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`arena_teleport_relay`, `Trigger`)
                      "
            }
        }

        //// The Three Trolldiers ////

