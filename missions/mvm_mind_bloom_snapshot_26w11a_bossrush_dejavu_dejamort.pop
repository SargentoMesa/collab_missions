    Wave // Main Boss - Captain Punch the MDXXVIII & Major Catastrophe
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					EntFire(`wave_init_arena_skeleheat_relay`, `Trigger`, null, 6)

                    if (!(`mvm_mind_bloom_playerattributes` in getroottable()))
                    {
                        IncludeScript(`mvm_mind_bloom_playerattributes`, getroottable())
                    }
                    if (MusicSystemMent.MasterEntity == null || !MusicSystemMent.MasterEntity.IsValid())
					{
						MusicSystemMent.ResetAll();
						MusicSystemMent.HookByName(`bignet`);
					}
					MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/where_the_true_enemy_lies.wav`, 2.0, 2.0, 0.75);
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`boss_rush_spawn_teleport_relay`, `Trigger`, null, 5)
                  "
        }

        ItemAttributes [$SIGSEGV] //Make compatible with the boss' damage multiplier list. Has no effect on other bots.
        {
            ItemName "The Air Strike"
            "special damage type" 1
        }
        ItemAttributes [$SIGSEGV] //Make compatible with the boss' damage multiplier list. Has no effect on other bots.
        {
            ItemName "The Beggar's Bazooka"
            "special damage type" 2
        }
        ItemAttributes [$SIGSEGV] //Make compatible with the boss' damage multiplier list. Has no effect on other bots.
        {
            ItemName "The Dragon's Fury"
            "special damage type" 3
        }
        ItemAttributes [$SIGSEGV] //Prevents the boss' stickies from being destroyed as it is meant to be indestructible. There are no other bots with stickybomb launchers in this mission.
        {
            ItemName "The Scottish Resistance"
            "stickies detonate stickies" 0
        }
        ItemAttributes [$SIGSEGV] //Prevents the boss' stickies from being destroyed as it is meant to be indestructible. There are no other bots with stickybomb launchers in this mission.
        {
            ItemName "The Quickiebomb Launcher"
            "stickies detonate stickies" 0
        }

        CustomWaveNumber 17
        CustomMaxWaveNumber 0
        RedTeamWipeCausesWaveLoss 1

        WaveSpawn
        {
            Name "teleporthotfix"
            WaitBeforeStarting 5.1

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`arena_teleport_relay`, `Trigger`)
                        MusicSystemMent.SetMusicTrack(``, 2.0, 2.0);
						EntFire(`tf_gamerules`, `PlayVO`, `boss_incoming.wav`, 2.4)
                      "
            }
        }

