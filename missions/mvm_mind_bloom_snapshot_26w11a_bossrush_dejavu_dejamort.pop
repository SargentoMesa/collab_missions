    Wave // Boss Gauntlet - Bigheaded Behemoth, TON 618 Black Hole Pyro, then General Bomber & King Burst
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    Convars.SetValue(`tf_bot_flag_escort_max_count`, 0)
                    
