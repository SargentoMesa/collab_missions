    // ADVANCED GAUNTLET //

    Wave // Main Boss - Mining Supervisor OR Field Marshal Mechanus
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    if (!(`mvm_mind_bloom_playerattributes` in getroottable()))
                    {
                        IncludeScript(`mvm_mind_bloom_playerattributes`, getroottable())
                    }
                    if (!(`alternatewaves` in getroottable()))
                    {
                        IncludeScript(`alternatewaves`, getroottable());
                    }
                    if (!(`mvm_mind_bloom_arena_rng` in getroottable()))
                    {
                        IncludeScript(`mvm_mind_bloom_arena_rng`, getroottable());
                    }
                    if (!(`buddhamode` in getroottable()))
                    {
                        IncludeScript(`buddhamode`, getroottable())
                    }
                    if (!(`miningop` in getroottable()))
                    {
                        IncludeScript(`miningop`, getroottable())
                    }
                    if (MusicSystemMent.MasterEntity == null || !MusicSystemMent.MasterEntity.IsValid())
					{
						MusicSystemMent.ResetAll();
						MusicSystemMent.HookByName(`bignet`);
					}
					MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/slimy_spring_galaxy.wav`, 2.0, 2.0, 0.75);

                    MindBloomRNG.AddRNGArena(`wave_init_arena_underground_relay`, `Wave5_MiningSupervisor`);
                    MindBloomRNG.AddRNGArena(`wave_init_arena_bogland_relay`, `Wave5_FieldMarshalMechanus`);
                    MindBloomRNG.InitRNGArena();

                    AlternateWaves.bTrackIcons = false;
				    AlternateWaves.ClearWaveIcons();

                    switch (MindBloomRNG.GlobalIndex)
                    {
                        case 0:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`soldier_boss_visor`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`sniper_bow`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`heavy`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`pyro`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
                            ])
                            break;
                        }

                        case 1:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`soldier_bison_rocket_spammer`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`scout`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`scout_bat_nys`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`soldier_mangler_v2`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
                            ])
                            break;
                        }
                    }
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)

                    AlternateWaves.ClearWaveIcons();

                    switch (MindBloomRNG.GlobalIndex)
                    {
                        case 0:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`soldier_boss_visor`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`sniper_bow`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`heavy`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`pyro`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
                            ])
                            break;
                        }

                        case 1:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`soldier_bison_rocket_spammer`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`scout`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`scout_bat_nys`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                                [`soldier_mangler_v2`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
                            ])
                        }
                    }

                    MindBloomRNG.StartRNGArena();
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`boss_rush_spawn_teleport_relay`, `Trigger`, null, 5)

                    AlternateWaves.bTrackIcons = true;
                  "
        }

        CustomMaxWaveNumber 0
        RedTeamWipeCausesWaveLoss 1

        WaveSpawn
        {
            Name "teleporthotfix"
            WaitBeforeStarting 5.1

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`arena_teleport_relay`, `Trigger`)
						EntFire(`tf_gamerules`, `PlayVO`, `boss_incoming.wav`, 2.4)
                        MusicSystemMent.SetMusicTrack(``, 2.0, 2.0);
                      "
            }
        }

        //// Mining Supervisor ////
        WaveSpawn
        {
            Name "Wave5_MiningSupervisor"
            StartDisabled 1
        }
        WaveSpawn // Boss
        {
            Name "Wave5_Boss-MiningSupervisor"
            WaitForAllSpawned "Wave5_MiningSupervisor"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 12.5
            WaitBetweenSpawns 0
            TotalCurrency 100

