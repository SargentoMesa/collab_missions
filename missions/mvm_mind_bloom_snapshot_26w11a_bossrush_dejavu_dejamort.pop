    Wave // Boss Gauntlet - Bad to the Bone, Skull Magician, then Tank Zombies OR Dr. Dismemberment, The Mann in Black then Captain Cognac
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    if (!(`mvm_mind_bloom_playerattributes` in getroottable()))
                    {
                        IncludeScript(`mvm_mind_bloom_playerattributes`, getroottable())
                    }
                    if (!(`alternatewaves` in getroottable()))
                    {
                        IncludeScript(`alternatewaves`, getroottable());
                    }
                    if (!(`mvm_mind_bloom_arena_rng` in getroottable()))
                    {
                        IncludeScript(`mvm_mind_bloom_arena_rng`, getroottable());
                    }

                    MindBloomRNG.AddRNGArena(`wave_init_arena_industrial_relay`, `Wave12_IndustrialGauntlet`);
                    MindBloomRNG.AddRNGArena(`wave_init_arena_rancher_relay`, `Wave12_RancherGauntlet`);
                    MindBloomRNG.InitRNGArena();

                    AlternateWaves.bTrackIcons = false;
				    AlternateWaves.ClearWaveIcons();

                    switch (MindBloomRNG.GlobalIndex)
                    {
                        case 0:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`dead_blu_lite`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`special_magicskull`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`heavy_zombie_arm2_lite`, 10, MVM_CLASS_FLAG_MINIBOSS]
                            ])
                            break;
                        }                     
                        case 1:
                        {
                            AlternateWaves.AddWaveIcons([
                                [``, 1, MVM_CLASS_FLAG_MINIBOSS],
                            ])
                            break;
                        }
                    }
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)

				    AlternateWaves.ClearWaveIcons();

                    switch (MindBloomRNG.GlobalIndex)
                    {
                        case 0:
                        {
                            AlternateWaves.AddWaveIcons([
                                [`dead_blu_lite`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`special_magicskull`, 1, MVM_CLASS_FLAG_MINIBOSS],
                                [`heavy_zombie_arm2_lite`, 10, MVM_CLASS_FLAG_MINIBOSS]
                            ])
                            break;
                        }                     
                        case 1:
                        {
                            AlternateWaves.AddWaveIcons([
                                [``, 1, MVM_CLASS_FLAG_MINIBOSS],
                            ])
                            break;
                        }
                    }

                    MindBloomRNG.StartRNGArena();
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`boss_rush_spawn_teleport_relay`, `Trigger`, null, 5)

                    AlternateWaves.bTrackIcons = true;
                  "
        }

        //// Bad to the Bone, Skull Magician & The Tank Zombies ////
        WaveSpawn
        {
            Name "Wave12_IndustrialGauntlet"
            StartDisabled 1
        }

        WaveSpawn // Boss 1 - Bad to the Bone
        {
            Name "Wave12_Boss1-BadtotheBone"
            WaitForAllSpawned "Wave12_IndustrialGauntlet"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 12.5
            WaitBetweenSpawns 0
            TotalCurrency 100

            TFBot
            {
                Template T_TFBot_BossRider
                Action Mobber
            }
            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`minibossmusicinit`, `Trigger`)
                      "
            }
            DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave12_Support-MiniBones`)
                        EntFire(`pop_interface`, `$PauseWaveSpawn`, `Wave12_Support-MiniBones`)
                        EntFire(`arena_industrial_boss_spawn_relay`, `Trigger`, null, 2.5)
                      "
            }
        }

        WaveSpawn // Support Mini Riders
        {
            Name "Wave12_Support-MiniBones"
            WaitForAllSpawned "Wave12_IndustrialGauntlet"
            Where spawnbot_support
            Support 1
            TotalCount 50
            MaxActive 3
            SpawnCount 1
            WaitBeforeStarting 20
            WaitBetweenSpawns 8
            TotalCurrency 100

            TFBot
            {
                Class Pyro
                Skill Easy
                ClassIcon dead_blu_lite
                Health 1100
                Attributes MiniBoss
                Action Mobber
                ExtAttr IgnoreBuildings  
                WeaponRestrictions MeleeOnly
                Item "The Pardner's Pompadour"
                Item "Merc's Pride Scarf"
                Name "Hell Rider"
                Scale 1.1
                NoIdleSound 1 			 
                UseHumanAnimations 1 	 
                AimTrackingInterval 1.5   
                FastUpdate 1 			 
                UseCustomModel "models/bots/skeleton_sniper/skeleton_sniper.mdl"  
                SpawnTemplate "SmallRider"
                DeathSound "=150|mvm\giant_soldier\giant_soldier_explode.wav" [$SIGSEGV]
                FireInput [$SIGSEGV]
                {
                    Target "!self"
                    Action "$TauntFromItem"
                    Param "Taunt: The Hot Wheeler|taunt move speed|225|taunt turn speed|50,0,-1" 
                    Delay 1
                    Repeats 1
                }
                ItemAttributes
                {
                    ItemName "TF_WEAPON_FIREAXE"
                    "custom kill icon" bumper_kart
                }
                CharacterAttributes
                {
                    "always allow taunt" 1  
                    "rage giving scale"	0
                    "voice pitch scale" 0
                    "damage causes airblast" 1
                    "stomp player force" 320
                    "stomp player damage" 50
                    "stomp player time" 0.3
                    "stomp building damage" 200
                    "damage force reduction" 0.2
                    "airblast vulnerability multiplier" 0.2
                    "bombinomicon effect on death" 1
                }
            }
        }
        WaveSpawn // Boss 2 - Skull Magician
