								[`engineer_beepboy`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`tank_combat_rocket_dual_kai`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`tank_combat_minigun_dual_kai`, 1, MVM_CLASS_FLAG_MINIBOSS],
