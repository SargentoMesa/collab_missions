                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$FinishWaveNoUnspawnedMoney`)
                      "
            }
        }
        WaveSpawn // Support Bowmen
        {
            Name "Wave5_Support-Bowmen"
            WaitForAllSpawned "Wave5_MiningSupervisor"
            Where spawnbot_support
            Support 1
            TotalCount 100
