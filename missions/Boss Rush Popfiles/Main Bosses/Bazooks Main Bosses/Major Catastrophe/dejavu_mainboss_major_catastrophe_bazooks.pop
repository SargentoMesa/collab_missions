WaveSchedule
{
    LuaScriptFile "scripts/skangus_event_boss_fire_attempt2.lua"

	ItemAttributes [$SIGSEGV] //Make compatible with the boss' damage multiplier list. Has no effect on other bots.
	{
		ItemName "The Air Strike"
		"special damage type" 1
	}
    ItemAttributes [$SIGSEGV] //Make compatible with the boss' damage multiplier list. Has no effect on other bots.
	{
		ItemName "The Beggar's Bazooka"
		"special damage type" 2
	}
    ItemAttributes [$SIGSEGV] //Make compatible with the boss' damage multiplier list. Has no effect on other bots.
	{
		ItemName "The Dragon's Fury"
		"special damage type" 3
	}
	ItemAttributes [$SIGSEGV] //Prevents the boss' stickies from being destroyed as it is meant to be indestructible. There are no other bots with stickybomb launchers in this mission.
	{
		ItemName "The Scottish Resistance"
		"stickies detonate stickies" 0
	}
	ItemAttributes [$SIGSEGV] //Prevents the boss' stickies from being destroyed as it is meant to be indestructible. There are no other bots with stickybomb launchers in this mission.
	{
		ItemName "The Quickiebomb Launcher"
		"stickies detonate stickies" 0
	}

    SpawnTemplate [$SIGSEGV] //Spawn template once the mission loads
	{
		Name "MajorCatastrophe_logic"
		//Origin "0 0 0" //Position where to spawn the template
		//Angles "0 0 0" //Rotation
	}

    PointTemplates
    {
        		MajorCatastrophe_logic
		{
			NoFixup 1
            logic_auto
            {
                //"OnMapSpawn" "tf_objective_resource,$SetClientProp$m_iszMvMPopfileName,When the Sun Shines Red,0,-1"
                "OnMapSpawn" "player,Color,255 255 255,0,-1"
                "OnMapSpawn" "demobosstargetname,AddOutput,targetname yes,1,-1"
                //"OnMapSpawn" "individualfiremaker,AddOutput,OnUser1 individualfiremaker:ForceSpawnAtEntityOrigin:spawnbot:0:-1,0,-1"
                //"OnMapSpawn" "tf_objective_resource,$SetClientProp$m_iChallengeIndex,1,0,-1"
            }
			logic_relay
            {
                "targetname" "MajorCatastrophe_nukestickies_scdeniedrelay"
                "ontrigger" "MajorCatastrophe_nukestickies_scdeniedsound*,PlaySound,0,0,-1"
                "ontrigger" "MajorCatastrophe_nukestickiesparticle_scdenied*,Start,0,0,-1"
                "ontrigger" "MajorCatastrophe_nukestickiesparticle_scdenied*,Stop,0,0.3,-1"
            }
			filter_tf_condition
            {
                "condition" "5"
                "Negated" "1"
                "targetname" "MajorCatastrophe_invulnfilter"
            }
            filter_tf_condition
            {
                "condition" "52"
                "Negated" "1"
                "targetname" "MajorCatastrophe_ubercanteenfilter"
            }
			filter_tf_condition
