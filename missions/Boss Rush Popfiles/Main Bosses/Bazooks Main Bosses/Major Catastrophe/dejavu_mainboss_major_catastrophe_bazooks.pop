		MajorCatastrophe_FireCannonballs
		{
			KeepAlive 1
            OnParentKilledOutput
			{
				Target "MajorCatastrophe_firecannonballs_relay"
				Action "trigger"
				Delay 0.00
				Param 1
			}
			ambient_generic
            {
                "targetname" "MajorCatastrophe_firecannonballs_sound"
                "message" "ambient\fire\firebig.wav"
                "health" "10"
                "radius" "2100"
                "spawnflags" "16"
                "origin" "0 0 100"
            }
			trigger_ignite
            {
                "targetname" "MajorCatastrophe_firecannonballs_triggerignite"
                "origin" "0 0 16"
                "mins" "-144 -144 -144"
                "maxs" "144 144 144"
                "burn_duration" "4"
                "damage_percent_per_second" "400"
                "filtername" "MajorCatastrophe_filter_red_notubered"
                "spawnflags" "1"
                "StartDisabled" "1"
            }
			logic_relay
            {
                "targetname" "MajorCatastrophe_firecannonballs_relay"
                "ontrigger" "MajorCatastrophe_firecannonballs_triggerignite,Enable,0,0.5,-1"
                "ontrigger" "MajorCatastrophe_firecannonballs_sound,PlaySound,0,0.25,-1"
                "ontrigger" "MajorCatastrophe_firecannonballs_sound,StopSound,0,3.75,-1"
                "ontrigger" "MajorCatastrophe_firecannonballs_triggerignite,Kill,0,3.5,-1"
                "ontrigger" "!self,Kill,0,4,-1"
            }
		}
		MajorCatastrophe_NukeStickies
		{
			KeepAlive 1
			OnSpawnOutput
			{
				Target "MajorCatastrophe_nukestickies_setuprelay"
				Action "trigger"
				Delay -1
				Param 1
			}
			OnParentKilledOutput
			{
				Target "MajorCatastrophe_nukestickies_boomrelay"
				Action "trigger"
				Delay 0.00
				Param 1
			}
			logic_relay
            {
                "targetname" "MajorCatastrophe_nukestickies_setuprelay"
                "ontrigger" "!parent,$SetVar$isbosssticky,1,-1,-1"
                //"ontrigger" "!parent,Kill,0,3,-1"
                "ontrigger" "tf_projectile_pipe_remote,SetDamageFilter,filter_damagetype_none,0,-1"
                "ontrigger" "tf_projectile_pipe_remote,$SetCollisionFilter,demobossstickycollisionfilter4,0,-1"
                "ontrigger" "MajorCatastrophe_nukestickiesparticle_chargeup,Start,0,3,-1"
                "ontrigger" "MajorCatastrophe_nukestickiesparticle_chargeup,Kill,0,9,-1"
                "ontrigger" "MajorCatastrophe_nukestickiesparticle_scdenied,Kill,0,9,-1"
                "ontrigger" "MajorCatastrophe_nukestickiesparticle_blowupwarning,Start,0,8,-1"
                //"ontrigger" "scnullifier_trigger,Kill,0,9,-1"
                "ontrigger" "MajorCatastrophe_nukestickiesparticle_blowupwarning,Kill,0,9,-1"
                "ontrigger" "MajorCatastrophe_stickynuke_warnsound,PlaySound,0,3,-1"
                "ontrigger" "MajorCatastrophe_stickynuke_warnsound,PlaySound,0,6,-1"
                "ontrigger" "MajorCatastrophe_stickynuke_warnsound,PlaySound,0,7.5,-1"
                "ontrigger" "MajorCatastrophe_stickynuke_warnsound,PlaySound,0,8.25.,-1"
                "ontrigger" "MajorCatastrophe_stickynuke_warnsound,PlaySound,0,8.625.,-1"
                "ontrigger" "MajorCatastrophe_stickynuke_warnsound,PlaySound,0,8.8125.,-1"
                "ontrigger" "MajorCatastrophe_stickynuke_warnsound,PlaySound,0,8.890625.,-1"
                "ontrigger" "MajorCatastrophe_stickynuke_warnsound,PlaySound,0,8.953125.,-1"
                "ontrigger" "!self,Kill,0,10,-1"
            }
			logic_relay
            {
                "targetname" "MajorCatastrophe_nukestickies_boomrelay"
                "ontrigger" "MajorCatastrophe_nukestickiesparticle_scdenied,Kill,0,0,-1"
                "ontrigger" "MajorCatastrophe_nukestickies_shaker,StartShake,0,0,-1"
                "ontrigger" "MajorCatastrophe_nukestickies_fade,Fade,0,0,-1"
                "ontrigger" "MajorCatastrophe_nukestickies_boomsound,PlaySound,0,0,-1"
                "ontrigger" "!self,Kill,0,0.5,-1"
            }
			info_particle_system
            {
                "origin" "0 0 0"
                "targetname" "MajorCatastrophe_nukestickiesparticle_blowupwarning"
                "start_active" "0"
                "flag_as_weather" "0"
                "effect_name" "nukesticky_blowupwarning"
            }
			info_particle_system
            {
                "origin" "0 0 0"
