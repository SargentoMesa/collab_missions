        boss
        {
			OnSpawnOutput
			{
				Target "boss_intro"
				Action "trigger"
				Delay 13
			}
			OnSpawnOutput
			{
				Target "upper_text"
				Action "Display"
				Delay 15.1
			}
			OnSpawnOutput
			{
				Target "text_lower"
				Action "Display"
				Delay 16
			}
			OnSpawnOutput
			{
				Target "muerte"
				Action $SetOwner
				Param "@p@boss_thingy"
				Delay 0
			}
