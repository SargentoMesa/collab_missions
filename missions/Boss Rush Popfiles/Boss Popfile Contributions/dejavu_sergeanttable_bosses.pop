        //// THE FOREMANN ////
        boss_dead_pyro_foremann
        {
            OnSpawnOutput
            {
                Target "pyrocosmetic*"
                Action "TurnOff"
            }
            OnParentKilledOutput
            {
                Target "cleanupbots"
                Action Enable
            }
            OnParentKilledOutput
            {
                Target "spawnbot*"
                Action disable
            }
            OnParentKilledOutput
            {
                Target "chief_pyro_down"
                Action "Enable"
            }
            OnParentKilledOutput
            {
                Target "tf_gamerules"
                Action "PlayVO"
                Param   "vo\mvm\mght\pyro_mvm_m_helpme01.mp3"
                Delay   "0.1"
            }
            OnParentKilledOutput
            {
                Target "blowthemf"
                Action "Enable"
                Delay 1.15
            }
            OnParentKilledOutput
            {
                Target "pyrocosmetic"
                Action "TurnOn"
            }
            OnParentKilledOutput
            {
                Target "chief_pyro_down"
                Action "SetPlaybackRate"
                Param "0.5"
                Delay 1.3
            }
            trigger_hurt
            {
                "targetname" "cleanupbots"
                "origin" "0 0 0"
                "mins" "-5000 -5000 -5000" //Trigger bounds, relative to origin
                "maxs" "5000 5000 5000"
