        //// PRIVATE MANNPOWER ////
        removepowerup // Kill on boss death with a delay of 0.1
        {
            RemoveIfKilled mannpower_kill
            logic_timer
            {
                "targetname" "mannpower_kill"
                "RefireTime" "0.01"
